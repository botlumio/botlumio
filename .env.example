# =============================================================
# Lumiobot — Environment Variables Template
# Copy this file to `.env` and fill in your real values.
# NEVER commit your real .env file to git.
# =============================================================

# --- Required ---

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Anthropic Claude API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Jina AI Reader API key (https://jina.ai)
JINA_API_KEY=your_jina_api_key

# --- Optional: on-chain TX verification (token launch) ---
ETHERSCAN_API_KEY=your_etherscan_api_key
BASESCAN_API_KEY=your_basescan_api_key

# Wallet address used to receive crypto payments (public, safe to share)
WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# --- Optional: limits & logging ---
MAX_DAILY_FREE=10
LOG_LEVEL=INFO
